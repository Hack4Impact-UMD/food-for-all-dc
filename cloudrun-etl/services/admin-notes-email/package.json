{
  "name": "admin-notes-summary",
  "version": "1.0.0",
  "description": "Cloud Function that summarizes notes changes across clients",
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "start": "functions-framework --target=admin-notes-summary --port=8080",
    "dev": "functions-framework --target=admin-notes-summary --port=8080",
    "deploy": "gcloud functions deploy admin-notes-summary --runtime nodejs22 --trigger-http --no-allow-unauthenticated"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "@google-cloud/functions-framework": "^3.1.4",
    "firebase-admin": "^11.0.0"
  }
}