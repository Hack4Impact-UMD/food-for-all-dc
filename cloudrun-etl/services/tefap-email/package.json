{
  "name": "tefap-email",
  "version": "1.0.0",
  "description": "Cloud Function that emails the weekly TEFAP cert report",
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "start": "functions-framework --target=tefap-email --port=8080",
    "dev": "functions-framework --target=tefap-email --port=8080",
    "deploy": "gcloud functions deploy tefap-email --runtime nodejs22 --trigger-http --allow-unauthenticated"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "@google-cloud/functions-framework": "^3.1.4",
    "firebase-admin": "^11.0.0"
  }
}